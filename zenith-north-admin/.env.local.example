# ── Zenith North Admin Panel ──────────────────────────────
# Copy this to .env.local and fill in values

# URL of the main Zenith North app
NEXT_PUBLIC_API_URL=http://localhost:3000

# Must match ADMIN_SECRET in the main app's .env.local
# This is how the admin panel authenticates with the main app API
NEXT_PUBLIC_ADMIN_SECRET=your-admin-secret-here
