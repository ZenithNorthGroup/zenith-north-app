# ── Clerk Auth ──────────────────────────────────────
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Clerk routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Database ────────────────────────────────────────
# Neon: https://neon.tech — or Supabase connection string
DATABASE_URL=postgresql://user:password@host/zenith_north?sslmode=require

# ── Redis (Upstash) ─────────────────────────────────
# https://upstash.com — serverless Redis for caching
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx

# ── Anthropic AI ────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Document Storage ────────────────────────────────
# Cloudflare R2 (S3-compatible, cheaper)
R2_ACCOUNT_ID=xxxxx
R2_ACCESS_KEY_ID=xxxxx
R2_SECRET_ACCESS_KEY=xxxxx
R2_BUCKET_NAME=zenith-north-documents
R2_PUBLIC_URL=https://documents.yourdomain.com

# ── Encryption ──────────────────────────────────────
# 32-byte key for AES-256 field encryption (SSN, account numbers)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=xxxxx

# ── App ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Twilio (native compliant SMS) ────────────────────────────
# Get from console.twilio.com
# Register for 10DLC through Twilio Trust Hub (~2-5 business days)
# This replaces MyRepChat — we own the compliance infrastructure
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
