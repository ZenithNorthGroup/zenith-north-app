# ═══════════════════════════════════════════════════════
#  ZENITH NORTH — Environment Variables
#  Copy to .env.local for local development
#  Add all of these to Vercel → Settings → Environment Variables
# ═══════════════════════════════════════════════════════

# ── Database (Neon PostgreSQL) ──────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── Authentication (Clerk) ──────────────────────────────
# Get from: clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx

# Webhook secret — from Clerk Dashboard → Webhooks → your endpoint
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Clerk URLs (set these in Clerk Dashboard too)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── AI (Anthropic) ──────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Credential Encryption ───────────────────────────────
# Generate with: openssl rand -hex 32
# CRITICAL: Never change this after storing credentials
# If you lose this key, all stored tenant credentials become unreadable
CREDENTIAL_ENCRYPTION_KEY=your-32-byte-hex-string-here

# ── Admin Panel Security ────────────────────────────────
# Secret header required for all /api/admin/* routes
# Generate with: openssl rand -hex 16
ADMIN_SECRET=your-admin-secret-here

# ── Cron Jobs (Upstash QStash) ──────────────────────────
# Secret to authenticate cron job requests
# Generate with: openssl rand -hex 16
CRON_SECRET=your-cron-secret-here

# ── Client Portal ───────────────────────────────────────
PORTAL_URL=https://portal.zenith-north.com
PORTAL_SECRET=your-portal-secret-here

# Main app URL (used for cross-service calls)
MAIN_API_URL=https://app.zenith-north.com
SERVICE_SECRET=your-service-secret-here

# ── Email Archiving (SendGrid Inbound Parse) ────────────
# Set up: sendgrid.com → Settings → Inbound Parse
# MX record: points to mx.sendgrid.net
# Route: ingest-{tenant-slug}@mail.zenith-north.com → POST /api/email/ingest
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# (Optional — only needed if sending outbound email)

# ── File Storage (Cloudflare R2) ────────────────────────
# Get from: Cloudflare → R2 → your bucket → Manage R2 API tokens
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=zenith-north-documents
R2_PUBLIC_URL=https://documents.zenith-north.com

# ═══════════════════════════════════════════════════════
#  PER-TENANT CREDENTIALS (stored encrypted in DB)
#  These are NOT set here — they are entered per-firm in
#  the admin panel → Firms → [firm] → Credentials
#
#  Channels:  Twilio, WhatsApp, LinkedIn, Twitter, Slack,
#             Microsoft Teams, Zoom, Deepgram
# ═══════════════════════════════════════════════════════
